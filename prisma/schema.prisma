// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ManualPaymentMethod {
  id          String   @id @default(cuid())
  name        String   // e.g., "CashApp", "Zelle", "Bitcoin"
  details     String   // e.g., "$FusionBars", "info@fusion.com", "bc1qxy2kgdygjrsqtzq2n0yrf2493p83kkfjhx0wlh"
  instructions String? // Optional instructions for checkout
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
}

model Order {
  id              String   @id @default(cuid())
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String
  shippingMethod  String?
  shippingPrice   Float    @default(0)
  totalAmount     Float
  status          String   @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  
  paymentMethodId String
  paymentMethod   ManualPaymentMethod @relation(fields: [paymentMethodId], references: [id])
  
  items           LineItem[]
  pointsEarned    Int      @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model LineItem {
  id          String   @id @default(cuid())
  orderId     String
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String?  // Can now optionally link to dynamic Product
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName String
  quantity    Int
  price       Float    // Price at the time of purchase
}

model Product {
  id           String     @id @default(cuid())
  slug         String     @unique
  name         String
  price        Float
  regularPrice Float?
  category     String
  description  String
  image        String
  weight       String?
  effects      String?    // Store as JSON string stringified array
  ingredients  String?    // Store as JSON string stringified array
  gallery      String?    // Store as JSON stringified array of URLs (up to 5)
  dosage       String?
  isActive     Boolean    @default(true)
  seoTitle     String?
  seoDescription String?
  targetKeyword String?
  seoKeywords  String?    // Comma-separated
  imageAlt     String?
  stock        Int        @default(100) // Default stock level
  isSubscribable Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  
  lineItems    LineItem[]
  reviews      Review[]
}

model Coupon {
  id          String   @id @default(cuid())
  code        String   @unique
  discount    Float    // Value of the discount
  type        String   // "PERCENTAGE" or "FIXED"
  isActive    Boolean  @default(true)
  usageCount  Int      @default(0)
  maxUsage    Int?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Review {
  id        String   @id @default(cuid())
  name      String
  email     String?
  content   String
  rating    Int      @default(5)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  status    String   @default("PENDING") // PENDING, APPROVED, SPAM, TRASH
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShippingSetting {
  id                String   @id @default(cuid())
  type              String   // "LOCAL" or "INTERNATIONAL"
  category1Name     String   @default("Standard")
  category1Price    Float    @default(0)
  category2Name     String   @default("Express")
  category2Price    Float    @default(0)
  updatedAt         DateTime @updatedAt
}

model BlogPost {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String
  content       String
  image         String?
  category      String   @default("Wellness & Microdosing")
  tags          String   @default("[]") // Store as JSON stringified array
  isPublic      Boolean  @default(true)
  allowComments Boolean  @default(true)
  author        String   @default("Fusion Shroom Bars")
  seoTitle      String?
  seoDescription String?
  targetKeyword String?
  seoKeywords   String?  // Comma-separated
  imageAlt      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  comments      Comment[]
}

model Comment {
  id         String   @id @default(cuid())
  name       String
  email      String?
  content    String
  blogPostId String
  blogPost   BlogPost @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  status     String   @default("PENDING") // PENDING, APPROVED, SPAM, TRASH
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}


model PageMetadata {
  id            String   @id @default(cuid())
  path          String   @unique // e.g., "/", "/about", "/shop"
  title         String?
  description   String?
  targetKeyword String?
  seoKeywords   String?  // Comma-separated
  imageAlt      String?
  updatedAt     DateTime @updatedAt
}

model LoyaltyAccount {
  id        String   @id @default(cuid())
  email     String   @unique
  points    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoyaltySetting {
  id              String   @id @default("default")
  pointsPerDollar Int      @default(1)
  redemptionValue Float    @default(0.01) // e.g. $0.01 per 1 point
  minPointsToUse  Int      @default(100)
  updatedAt       DateTime @updatedAt
}

model BulkDiscountSetting {
  id              String   @id @default("default")
  tier1Qty        Int      @default(5)
  tier1Discount   Float    @default(0.10)
  tier2Qty        Int      @default(10)
  tier2Discount   Float    @default(0.20)
  updatedAt       DateTime @updatedAt
}

model MediaAsset {
  id               String   @id @default(cuid())
  filename         String
  originalFilename String
  mimeType         String
  size             Int      // bytes
  url              String
  altText          String?
  caption          String?
  folderId         String?
  folder           MediaFolder? @relation(fields: [folderId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model MediaFolder {
  id        String       @id @default(cuid())
  name      String
  parentId  String?
  parent    MediaFolder? @relation("SubFolders", fields: [parentId], references: [id])
  children  MediaFolder[] @relation("SubFolders")
  assets    MediaAsset[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}
